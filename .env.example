# Zkopírujte do Vercel → Settings → Environment Variables
RESEND_API_KEY=re_xxxxxxxx
INQUIRY_FROM_EMAIL=Poptávka <poptavka@paskyspotiskem.cz>

# Příjemci jsou v kódu (vojtech + karel). Přepište jen při testování:
# INQUIRY_TO_EMAILS=vojtech.petrak@alfain.eu,karel.petrak@alfain.eu

# --- Admin (/admin) – správa info baru ---
# Lokálně: zkopírujte do .env.local a spusťte `npm run dev`
# Produkce: Vercel → Project → Settings → Environment Variables
ADMIN_USERNAME=admin
ADMIN_PASSWORD=alfain
ADMIN_SESSION_SECRET=min-16-znaku-nahodny-retezec

# Vercel Blob (Storage → Blob → Create store → token)
# Nutné na produkci, aby uložení z /admin přežilo deploy
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# Volitelné: lepší překlady (jinak se použije MyMemory)
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_TRANSLATE_MODEL=gpt-4o-mini
